# Telegram Bot (optional — for contact form notifications)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Email SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=contact@yourdomain.com

# WHMCS API (optional — for WHMCS migration/import)
WHMCS_URL=https://your-whmcs-domain.com
WHMCS_IDENTIFIER=your-whmcs-api-identifier
WHMCS_SECRET=your-whmcs-api-secret
